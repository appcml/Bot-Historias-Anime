# ============================================
# BOT HISTORIAS - PLANTILLA
# ============================================

# Facebook (REQUERIDO)
FB_PAGE_ID=tu_id_de_pagina_aqui
FB_ACCESS_TOKEN=tu_token_largo_aqui

# Instagram (Opcional)
IG_ACCOUNT_ID=tu_id_de_instagram_aqui

# ============================================
# CONFIGURACIÓN DE HISTORIAS
# ============================================

# Intervalo entre historias en minutos
# 96 = 15 historias/día | 60 = 24 historias/día | 120 = 12 historias/día
INTERVALO_MINUTOS=96
MAX_HISTORIAS_DIA=15

# Cuántos días atrás buscar posts (30 = último mes)
DIAS_ATRAS=30

# ============================================
# OPENROUTER (Opcional)
# ============================================
OPENROUTER_API_KEY=tu_api_key_de_openrouter_aqui

# ============================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Obtén FB_PAGE_ID y FB_ACCESS_TOKEN en:
#    https://developers.facebook.com/tools/explorer/
# 3. Selecciona permisos: pages_read_engagement, pages_manage_posts
# ============================================
